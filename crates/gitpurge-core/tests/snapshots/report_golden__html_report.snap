                <th>Branch Name</th><th>Last Commit</th><th>Author</th><th>Type</th><th>Reason</th>
            </tr></thead><tbody><tr><td><code>feature/login</code></td><td>2026-07-17</td><td>Alice Developer</td><td>Local</td><td><span class="badge badge-danger">Merged</span></td></tr></tbody></table><h3>💻 Quick Commands</h3><pre>git-purge delete --repo test-repo --branch feature/login --execute
</pre></div><div class="card"><h2>⚠️ Naming Standards Violations</h2><table><thead><tr>
                <th>Branch Name</th><th>Last Commit</th><th>Author</th><th>Issue</th>
            </tr></thead><tbody><tr><td><code>wip-stub</code></td><td>2026-07-16</td><td>Alice Developer</td><td>Missing category prefix</td></tr></tbody></table></div><div class="card"><h2>📅 Categorization of Stale Branches by Age</h2><div class="stale-bucket"><h3>1–2 Years Old</h3><p>No branches in this age group.</p></div><div class="stale-bucket"><h3>2–3 Years Old</h3><table><thead><tr>
                        <th>Branch Name</th><th>Last Commit</th><th>Author</th><th>Merged?</th><th>Type</th>
                    </tr></thead><tbody><tr><td><code>wip-stub</code></td><td>2026-07-16</td><td>Alice Developer</td><td><span class="badge badge-warning">No</span></td><td>Local</td></tr></tbody></table></div><div class="stale-bucket"><h3>3+ Years Old</h3><p>No branches in this age group.</p></div></div><div class="card"><h2>🔍 Stale Branches: Review Required (Unmerged)</h2><table><thead><tr>
                <th>Branch Name</th><th>Last Commit</th><th>Author</th><th>Last Commit Message</th><th>Type</th>
            </tr></thead><tbody><tr><td><code>wip-stub</code></td><td>2026-07-16</td><td>Alice Developer</td><td>Wip login stub</td><td>Local</td></tr></tbody></table></div><div class="card"><h2>🔄 Compare against Previous Run</h2><p class="subtitle">Comparing to run on 2026-07-16 11:06 UTC</p><table><thead><tr>
                    <th>Metric</th><th>Old Value</th><th>New Value</th><th>Absolute Change</th><th>Change Ratio</th>
                </tr></thead><tbody><tr><td><strong>Total Branches</strong></td><td>10</td><td>3</td><td><span class="badge badge-success">-7</span></td><td>-70.0%</td></tr><tr><td><strong>Stale Branches</strong></td><td>5</td><td>1</td><td><span class="badge badge-success">-4</span></td><td>-80.0%</td></tr><tr><td><strong>Active Branches</strong></td><td>5</td><td>2</td><td><span class="badge badge-success">-3</span></td><td>-60.0%</td></tr><tr><td><strong>Merged Branches</strong></td><td>2</td><td>2</td><td><span class="badge badge-info">0</span></td><td>0.0%</td></tr><tr><td><strong>Unmerged Branches</strong></td><td>8</td><td>1</td><td><span class="badge badge-success">-7</span></td><td>-87.5%</td></tr><tr><td><strong>Non-Standard Naming</strong></td><td>3</td><td>1</td><td><span class="badge badge-success">-2</span></td><td>-66.7%</td></tr></tbody></table></div></div></body></html>
