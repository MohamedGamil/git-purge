'--name=[Human label for the repository]:NAME:_default' \
'--default-branch=[Override default branch auto-detection (e.g. '\''main'\'', '\''master'\'')]:DEFAULT_BRANCH:_default' \
'--remote=[Register an extra remote URL]:REMOTE:_default' \
