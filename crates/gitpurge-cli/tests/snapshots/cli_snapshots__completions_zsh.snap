(( $+functions[_git-purge_commands] )) ||
_git-purge_commands() {
    local commands; commands=(
'repo:Manage tracked repositories' \
'scan:Classify branches (read-only scan)' \
'plan:Show what delete/archive would do (dry-run)' \
'backup:Manage backup snapshots' \
'delete:Delete stale/merged branches (dry-run default)' \
'archive:Archive unmerged branches into a legacy branch' \
'restore:Restore a branch or tag from a snapshot' \
'diff:Compare two branches' \
'show:View repo/file content at a ref/commit' \
'report:Generate audit and trend reports' \
'history:View trend history' \
'auth:Manage authentication credentials' \
'ui:Launch the desktop UI (if installed)' \
'install-cli:Install git-purge on PATH' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'git-purge commands' commands "$@"
}
(( $+functions[_git-purge__subcmd__archive_commands] )) ||
_git-purge__subcmd__archive_commands() {
    local commands; commands=()
    _describe -t commands 'git-purge archive commands' commands "$@"
}
(( $+functions[_git-purge__subcmd__auth_commands] )) ||
_git-purge__subcmd__auth_commands() {
    local commands; commands=(
'add:Add a credential' \
'list:List stored credentials' \
'remove:Remove a credential' \
'test:Test credentials for a host or repository' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'git-purge auth commands' commands "$@"
}
