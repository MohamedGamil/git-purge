#compdef git-purge

autoload -U is-at-least

_git-purge() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--config=[Path to config file (default\: auto-resolved via XDG/KnownFolders)]:CONFIG:_default' \
'--repo=[Target repository (id, label, or path). Defaults to the default_repo in config or current directory]:REPO:_default' \
'--data-dir=[Override the data root directory (history DB, backups, reports)]:DATA_DIR:_default' \
'--json[Output as JSON instead of human-readable tables]' \
'--no-color[Suppress colored output]' \
'-y[Assume "yes" for standard confirmations]' \
'--yes[Assume "yes" for standard confirmations]' \
'-e[Perform mutations. Absent => dry-run]' \
'--execute[Perform mutations. Absent => dry-run]' \
'*-v[Increase verbosity (-v, -vv)]' \
'*--verbose[Increase verbosity (-v, -vv)]' \
'-q[Suppress all output except errors]' \
'--quiet[Suppress all output except errors]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_git-purge_commands" \
"*::: :->git-purge" \
&& ret=0
    case $state in
    (git-purge)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:git-purge-command-$line[1]:"
        case $line[1] in
            (repo)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to config file (default\: auto-resolved via XDG/KnownFolders)]:CONFIG:_default' \
'--repo=[Target repository (id, label, or path). Defaults to the default_repo in config or current directory]:REPO:_default' \
'--data-dir=[Override the data root directory (history DB, backups, reports)]:DATA_DIR:_default' \
'--json[Output as JSON instead of human-readable tables]' \
'--no-color[Suppress colored output]' \
'-y[Assume "yes" for standard confirmations]' \
'--yes[Assume "yes" for standard confirmations]' \
'-e[Perform mutations. Absent => dry-run]' \
'--execute[Perform mutations. Absent => dry-run]' \
'*-v[Increase verbosity (-v, -vv)]' \
'*--verbose[Increase verbosity (-v, -vv)]' \
'-q[Suppress all output except errors]' \
'--quiet[Suppress all output except errors]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_git-purge__subcmd__repo_commands" \
"*::: :->repo" \
&& ret=0

    case $state in
    (repo)
        words=($line[1] "${words[@]}")
